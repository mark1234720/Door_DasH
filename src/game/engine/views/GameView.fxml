<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<!--
    GameView.fxml  —  DooR DasH Milestone 3
    ==========================================
    SceneBuilder-compatible layout.
    All fx:id values match @FXML fields in GameController.java exactly.
    The boardGrid (center) is populated at runtime by GameController.buildBoard().
    Do NOT rename any fx:id — they are wired to the controller.
-->
<BorderPane
    prefHeight="820.0"
    prefWidth="1280.0"
    style="-fx-background-color: #0d0d1a;"
    xmlns="http://javafx.com/javafx/17"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="game.engine.views.GameController">

    <!-- ═══════════════════════════════════════
         TOP BAR
         ═══════════════════════════════════════ -->
    <top>
        <HBox
            alignment="CENTER_LEFT"
            prefHeight="52.0"
            spacing="16.0"
            style="-fx-background-color: #1a1a2e; -fx-border-color: #e94560; -fx-border-width: 0 0 2 0;">
            <padding><Insets bottom="0" left="20" right="20" top="0" /></padding>

            <!-- Logo -->
            <Label
                text="👁 DooR DasH"
                style="-fx-text-fill: #e94560; -fx-font-size: 20px; -fx-font-weight: bold; -fx-font-family: 'Monospace';" />

            <Region HBox.hgrow="ALWAYS" />

            <!-- Turn counter -->
            <HBox alignment="CENTER" spacing="8"
                  style="-fx-background-color: #16213e; -fx-background-radius: 20; -fx-padding: 6 16 6 16;">
                <Label text="TURN"
                       style="-fx-text-fill: #888; -fx-font-size: 11px; -fx-font-weight: bold;" />
                <Label fx:id="turnLabel" text="1"
                       style="-fx-text-fill: #f5a623; -fx-font-size: 18px; -fx-font-weight: bold;" />
            </HBox>

            <Region HBox.hgrow="ALWAYS" />

            <!-- Whose turn indicator -->
            <Label fx:id="currentPlayerLabel" text="YOUR TURN"
                   style="-fx-text-fill: #00d4aa; -fx-font-size: 14px; -fx-font-weight: bold;
                          -fx-background-color: #0a3d2e; -fx-background-radius: 20;
                          -fx-padding: 6 18 6 18;" />
        </HBox>
    </top>

    <!-- ═══════════════════════════════════════
         LEFT  —  YOUR monster panel
         ═══════════════════════════════════════ -->
    <left>
        <VBox
            prefWidth="195.0"
            spacing="0.0"
            style="-fx-background-color: #16213e; -fx-border-color: #00d4aa; -fx-border-width: 0 2 0 0;">

            <!-- Panel header -->
            <HBox alignment="CENTER"
                  style="-fx-background-color: #00d4aa; -fx-padding: 8 12 8 12;">
                <Label text="⚔  YOUR MONSTER"
                       style="-fx-text-fill: #0d0d1a; -fx-font-weight: bold; -fx-font-size: 12px;" />
            </HBox>

            <VBox spacing="10.0" VBox.vgrow="ALWAYS">
                <padding><Insets bottom="14" left="12" right="12" top="14" /></padding>

                <!-- Monster name -->
                <Label fx:id="playerName" text="Loading..."
                       wrapText="true"
                       style="-fx-text-fill: #ffffff; -fx-font-size: 15px; -fx-font-weight: bold;" />

                <!-- Type chip -->
                <HBox alignment="CENTER_LEFT" spacing="6">
                    <Label text="TYPE"
                           style="-fx-text-fill: #888; -fx-font-size: 10px; -fx-font-weight: bold;" />
                    <Label fx:id="playerType" text="—"
                           style="-fx-text-fill: #f5a623; -fx-font-size: 12px; -fx-font-weight: bold;
                                  -fx-background-color: #2a1f00; -fx-background-radius: 8;
                                  -fx-padding: 2 8 2 8;" />
                </HBox>

                <Separator style="-fx-background-color: #2a2a4a;" />

                <!-- Original role -->
                <HBox alignment="CENTER_LEFT" spacing="8">
                    <Label text="ORIG ROLE"
                           style="-fx-text-fill: #888; -fx-font-size: 10px; -fx-font-weight: bold; -fx-min-width: 70;" />
                    <Label fx:id="playerOrigRole" text="—"
                           style="-fx-text-fill: #ccc; -fx-font-size: 12px;" />
                </HBox>

                <!-- Current role (turns orange+warning when confused) -->
                <HBox alignment="CENTER_LEFT" spacing="8">
                    <Label text="CURR ROLE"
                           style="-fx-text-fill: #888; -fx-font-size: 10px; -fx-font-weight: bold; -fx-min-width: 70;" />
                    <Label fx:id="playerCurrRole" text="—"
                           style="-fx-text-fill: #00d4aa; -fx-font-size: 12px; -fx-font-weight: bold;" />
                </HBox>

                <Separator style="-fx-background-color: #2a2a4a;" />

                <!-- Energy -->
                <VBox spacing="4">
                    <Label text="⚡ ENERGY"
                           style="-fx-text-fill: #888; -fx-font-size: 10px; -fx-font-weight: bold;" />
                    <Label fx:id="playerEnergy" text="0"
                           style="-fx-text-fill: #f5a623; -fx-font-size: 26px; -fx-font-weight: bold;" />
                </VBox>

                <!-- Position -->
                <HBox alignment="CENTER_LEFT" spacing="8">
                    <Label text="📍 CELL"
                           style="-fx-text-fill: #888; -fx-font-size: 10px; -fx-font-weight: bold; -fx-min-width: 70;" />
                    <Label fx:id="playerPos" text="0"
                           style="-fx-text-fill: #ffffff; -fx-font-size: 14px; -fx-font-weight: bold;" />
                </HBox>

                <Separator style="-fx-background-color: #2a2a4a;" />

                <!-- Status effects — chips injected here at runtime -->
                <Label text="STATUS EFFECTS"
                       style="-fx-text-fill: #888; -fx-font-size: 10px; -fx-font-weight: bold;" />
                <VBox fx:id="playerStatusBox" spacing="5.0" />
            </VBox>
        </VBox>
    </left>

    <!-- ═══════════════════════════════════════
         CENTER  —  Game board (100 cells)
         ═══════════════════════════════════════ -->
    <center>
        <StackPane style="-fx-background-color: #0d0d1a;">
            <!--
                boardGrid is EMPTY here — GameController.buildBoard() fills it
                with 100 styled StackPane cells at startup.
                Each cell gets styleClass from getCellStyleClass() based on its type.
            -->
            <GridPane
                fx:id="boardGrid"
                alignment="CENTER"
                hgap="3.0"
                vgap="3.0">
                <padding><Insets bottom="12" left="12" right="12" top="12" /></padding>
            </GridPane>
        </StackPane>
    </center>

    <!-- ═══════════════════════════════════════
         RIGHT  —  Opponent panel + Game log
         ═══════════════════════════════════════ -->
    <right>
        <VBox prefWidth="200.0" spacing="0.0"
              style="-fx-background-color: #16213e; -fx-border-color: #e94560; -fx-border-width: 0 0 0 2;">

            <!-- Opponent panel header -->
            <HBox alignment="CENTER"
                  style="-fx-background-color: #e94560; -fx-padding: 8 12 8 12;">
                <Label text="💀  OPPONENT"
                       style="-fx-text-fill: #ffffff; -fx-font-weight: bold; -fx-font-size: 12px;" />
            </HBox>

            <VBox spacing="10.0">
                <padding><Insets bottom="14" left="12" right="12" top="14" /></padding>

                <Label fx:id="opponentName" text="Loading..."
                       wrapText="true"
                       style="-fx-text-fill: #ffffff; -fx-font-size: 15px; -fx-font-weight: bold;" />

                <HBox alignment="CENTER_LEFT" spacing="6">
                    <Label text="TYPE"
                           style="-fx-text-fill: #888; -fx-font-size: 10px; -fx-font-weight: bold;" />
                    <Label fx:id="opponentType" text="—"
                           style="-fx-text-fill: #f5a623; -fx-font-size: 12px; -fx-font-weight: bold;
                                  -fx-background-color: #2a1f00; -fx-background-radius: 8;
                                  -fx-padding: 2 8 2 8;" />
                </HBox>

                <Separator style="-fx-background-color: #2a2a4a;" />

                <HBox alignment="CENTER_LEFT" spacing="8">
                    <Label text="ORIG ROLE"
                           style="-fx-text-fill: #888; -fx-font-size: 10px; -fx-font-weight: bold; -fx-min-width: 70;" />
                    <Label fx:id="opponentOrigRole" text="—"
                           style="-fx-text-fill: #ccc; -fx-font-size: 12px;" />
                </HBox>

                <HBox alignment="CENTER_LEFT" spacing="8">
                    <Label text="CURR ROLE"
                           style="-fx-text-fill: #888; -fx-font-size: 10px; -fx-font-weight: bold; -fx-min-width: 70;" />
                    <Label fx:id="opponentCurrRole" text="—"
                           style="-fx-text-fill: #e94560; -fx-font-size: 12px; -fx-font-weight: bold;" />
                </HBox>

                <Separator style="-fx-background-color: #2a2a4a;" />

                <VBox spacing="4">
                    <Label text="⚡ ENERGY"
                           style="-fx-text-fill: #888; -fx-font-size: 10px; -fx-font-weight: bold;" />
                    <Label fx:id="opponentEnergy" text="0"
                           style="-fx-text-fill: #e94560; -fx-font-size: 26px; -fx-font-weight: bold;" />
                </VBox>

                <HBox alignment="CENTER_LEFT" spacing="8">
                    <Label text="📍 CELL"
                           style="-fx-text-fill: #888; -fx-font-size: 10px; -fx-font-weight: bold; -fx-min-width: 70;" />
                    <Label fx:id="opponentPos" text="0"
                           style="-fx-text-fill: #ffffff; -fx-font-size: 14px; -fx-font-weight: bold;" />
                </HBox>

                <Separator style="-fx-background-color: #2a2a4a;" />

                <Label text="STATUS EFFECTS"
                       style="-fx-text-fill: #888; -fx-font-size: 10px; -fx-font-weight: bold;" />
                <VBox fx:id="opponentStatusBox" spacing="5.0" />
            </VBox>

            <!-- Spacer to push log to bottom half -->
            <Region VBox.vgrow="ALWAYS" />

            <!-- Game Log -->
            <VBox spacing="6.0"
                  style="-fx-border-color: #2a2a4a; -fx-border-width: 1 0 0 0;"
                  VBox.vgrow="ALWAYS">
                <padding><Insets bottom="10" left="10" right="10" top="10" /></padding>

                <HBox alignment="CENTER_LEFT" spacing="6">
                    <Label text="📜"
                           style="-fx-font-size: 11px;" />
                    <Label text="GAME LOG"
                           style="-fx-text-fill: #f5a623; -fx-font-size: 11px; -fx-font-weight: bold;" />
                </HBox>
                <Separator style="-fx-background-color: #f5a623; -fx-opacity: 0.4;" />

                <ScrollPane
                    fx:id="logScroll"
                    fitToWidth="true"
                    prefHeight="240.0"
                    hbarPolicy="NEVER"
                    style="-fx-background: transparent; -fx-background-color: transparent;"
                    VBox.vgrow="ALWAYS">
                    <VBox fx:id="logBox" spacing="5.0">
                        <padding><Insets bottom="4" left="2" right="4" top="2" /></padding>
                    </VBox>
                </ScrollPane>
            </VBox>

        </VBox>
    </right>

    <!-- ═══════════════════════════════════════
         BOTTOM  —  Dice result + Action buttons
         ═══════════════════════════════════════ -->
    <bottom>
        <VBox spacing="0.0"
              style="-fx-background-color: #1a1a2e; -fx-border-color: #e94560; -fx-border-width: 2 0 0 0;">

            <!-- Result info row -->
            <HBox
                alignment="CENTER"
                prefHeight="52.0"
                spacing="0.0"
                style="-fx-background-color: #12122a;">

                <!-- Dice result box -->
                <HBox alignment="CENTER" spacing="10"
                      prefWidth="200"
                      style="-fx-border-color: #2a2a4a; -fx-border-width: 0 1 0 0; -fx-padding: 8 20 8 20;">
                    <Label text="🎲 DICE"
                           style="-fx-text-fill: #888; -fx-font-size: 11px; -fx-font-weight: bold;" />
                    <Label fx:id="diceLabel" text="—"
                           style="-fx-text-fill: #f5a623; -fx-font-size: 22px; -fx-font-weight: bold;" />
                </HBox>

                <!-- Last event description -->
                <HBox alignment="CENTER_LEFT" spacing="10"
                      HBox.hgrow="ALWAYS"
                      style="-fx-padding: 8 20 8 20;">
                    <Label text="⚡ EVENT"
                           style="-fx-text-fill: #888; -fx-font-size: 11px; -fx-font-weight: bold; -fx-min-width: 60;" />
                    <Label fx:id="eventLabel" text="Waiting for first roll..."
                           wrapText="true"
                           style="-fx-text-fill: #cccccc; -fx-font-size: 12px;" />
                </HBox>
            </HBox>

            <!-- Action buttons row -->
            <HBox
                alignment="CENTER"
                prefHeight="56.0"
                spacing="20.0"
                style="-fx-background-color: #1a1a2e; -fx-padding: 8 20 8 20;">

                <!--
                    powerupBtn: calls game.usePowerup() via onUsePowerup().
                    Costs POWERUP_COST (500) energy. Must be used BEFORE rolling.
                    Disabled when it's opponent's turn.
                -->
                <Button
                    fx:id="powerupBtn"
                    mnemonicParsing="false"
                    onAction="#onUsePowerup"
                    prefHeight="38.0"
                    prefWidth="200.0"
                    text="⚡  USE POWERUP  (-500)"
                    style="-fx-background-color: #f5a623; -fx-text-fill: #0d0d1a;
                           -fx-font-weight: bold; -fx-font-size: 12px;
                           -fx-background-radius: 20; -fx-cursor: hand;" />

                <!--
                    rollBtn: calls game.playTurn() via onRoll().
                    After clicking, the engine rolls dice internally, moves the monster,
                    triggers onLand() for the cell, then switches turns.
                    Disabled when it's opponent's turn (opponent auto-plays).
                -->
                <Button
                    fx:id="rollBtn"
                    mnemonicParsing="false"
                    onAction="#onRoll"
                    prefHeight="38.0"
                    prefWidth="200.0"
                    text="🎲  ROLL DICE"
                    style="-fx-background-color: #e94560; -fx-text-fill: #ffffff;
                           -fx-font-weight: bold; -fx-font-size: 14px;
                           -fx-background-radius: 20; -fx-cursor: hand;" />
            </HBox>
        </VBox>
    </bottom>

</BorderPane>
