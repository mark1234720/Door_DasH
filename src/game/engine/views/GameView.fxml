<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane
    prefHeight="820.0"
    prefWidth="1280.0"
    style="-fx-background-color: #0a4d6e;"
    xmlns="http://javafx.com/javafx/17"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="game.engine.views.GameController">

    <!-- TOP BAR -->
    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="58.0" spacing="16.0"
              style="-fx-background-color: #7b2d8b;
                     -fx-border-color: #f9d71c; -fx-border-width: 0 0 4 0;
                     -fx-effect: dropshadow(gaussian, #00000088, 10, 0, 0, 4);">
            <padding><Insets bottom="0" left="20" right="20" top="0" /></padding>

            <HBox alignment="CENTER" spacing="10">
                <ImageView fx:id="logoImage" fitHeight="44" fitWidth="44" preserveRatio="true" />
                <VBox alignment="CENTER_LEFT" spacing="1">
                    <Label text="DooR DaSH"
                           style="-fx-text-fill: #f9d71c; -fx-font-size: 22px; -fx-font-weight: bold;" />
                    <Label text="SCARE  vs  LAUGH  TOUCHDOWN"
                           style="-fx-text-fill: #e8c0f0; -fx-font-size: 9px; -fx-font-weight: bold;" />
                </VBox>
            </HBox>

            <Region HBox.hgrow="ALWAYS" />

            <VBox alignment="CENTER"
                  style="-fx-background-color: #4a1a5e; -fx-background-radius: 14;
                         -fx-border-color: #f9d71c; -fx-border-radius: 14; -fx-border-width: 2;
                         -fx-padding: 4 22 4 22;">
                <Label text="TURN"
                       style="-fx-text-fill: #e8c0f0; -fx-font-size: 9px; -fx-font-weight: bold;" />
                <Label fx:id="turnLabel" text="1"
                       style="-fx-text-fill: #f9d71c; -fx-font-size: 24px; -fx-font-weight: bold;" />
            </VBox>

            <Region HBox.hgrow="ALWAYS" />

            <Label fx:id="currentPlayerLabel" text="YOUR TURN"
                   style="-fx-text-fill: #0a4d6e; -fx-font-size: 13px; -fx-font-weight: bold;
                          -fx-background-color: #a8e063; -fx-background-radius: 22;
                          -fx-padding: 8 22 8 22;
                          -fx-effect: dropshadow(gaussian, #a8e06388, 8, 0, 0, 2);" />
        </HBox>
    </top>

    <!-- LEFT — YOUR MONSTER -->
    <left>
        <VBox prefWidth="200.0" spacing="0.0"
              style="-fx-background-color: #063a52;
                     -fx-border-color: #a8e063; -fx-border-width: 0 4 0 0;
                     -fx-effect: dropshadow(gaussian, #00000066, 8, 0, 0, 0);">

            <HBox alignment="CENTER"
                  style="-fx-background-color: #a8e063; -fx-padding: 10 12 10 12;">
                <Label text="⚔  YOUR MONSTER"
                       style="-fx-text-fill: #063a52; -fx-font-weight: bold; -fx-font-size: 12px;" />
            </HBox>

            <!-- Monster portrait -->
            <StackPane prefHeight="110"
                       style="-fx-background-color: #042a3c;">
                <ImageView fx:id="playerImage" fitHeight="100" fitWidth="100"
                           preserveRatio="true" pickOnBounds="true" />
            </StackPane>

            <VBox spacing="8.0" VBox.vgrow="ALWAYS"
                  style="-fx-background-color: #063a52;">
                <padding><Insets bottom="12" left="12" right="12" top="10" /></padding>

                <Label fx:id="playerName" text="Loading..."
                       wrapText="true"
                       style="-fx-text-fill: #f9d71c; -fx-font-size: 14px; -fx-font-weight: bold;" />

                <HBox alignment="CENTER_LEFT" spacing="6">
                    <Label text="TYPE"
                           style="-fx-text-fill: #7acce0; -fx-font-size: 9px; -fx-font-weight: bold;" />
                    <Label fx:id="playerType" text="—"
                           style="-fx-text-fill: #063a52; -fx-font-size: 11px; -fx-font-weight: bold;
                                  -fx-background-color: #a8e063; -fx-background-radius: 6;
                                  -fx-padding: 2 8 2 8;" />
                </HBox>

                <Separator style="-fx-background-color: #0a6080;" />

                <HBox alignment="CENTER_LEFT" spacing="6">
                    <Label text="ORIG"
                           style="-fx-text-fill: #7acce0; -fx-font-size: 9px; -fx-font-weight: bold; -fx-min-width: 36;" />
                    <Label fx:id="playerOrigRole" text="—"
                           style="-fx-text-fill: #cceeff; -fx-font-size: 11px;" />
                </HBox>

                <HBox alignment="CENTER_LEFT" spacing="6">
                    <Label text="CURR"
                           style="-fx-text-fill: #7acce0; -fx-font-size: 9px; -fx-font-weight: bold; -fx-min-width: 36;" />
                    <Label fx:id="playerCurrRole" text="—"
                           style="-fx-text-fill: #a8e063; -fx-font-size: 11px; -fx-font-weight: bold;" />
                </HBox>

                <Separator style="-fx-background-color: #0a6080;" />

                <VBox spacing="2">
                    <Label text="⚡ ENERGY"
                           style="-fx-text-fill: #7acce0; -fx-font-size: 9px; -fx-font-weight: bold;" />
                    <Label fx:id="playerEnergy" text="0"
                           style="-fx-text-fill: #f9d71c; -fx-font-size: 30px; -fx-font-weight: bold;" />
                </VBox>

                <HBox alignment="CENTER_LEFT" spacing="6">
                    <Label text="📍 CELL"
                           style="-fx-text-fill: #7acce0; -fx-font-size: 9px; -fx-font-weight: bold;" />
                    <Label fx:id="playerPos" text="0"
                           style="-fx-text-fill: #ffffff; -fx-font-size: 13px; -fx-font-weight: bold;" />
                </HBox>

                <Separator style="-fx-background-color: #0a6080;" />

                <Label text="STATUS"
                       style="-fx-text-fill: #7acce0; -fx-font-size: 9px; -fx-font-weight: bold;" />
                <VBox fx:id="playerStatusBox" spacing="4.0" />
            </VBox>
        </VBox>
    </left>

    <!-- CENTER — BOARD -->
    <center>
        <StackPane style="-fx-background-color: #0a4d6e;">
            <ImageView fx:id="boardBg" fitWidth="880" fitHeight="720"
                       opacity="0.06" preserveRatio="false" pickOnBounds="false" />
            <GridPane fx:id="boardGrid" alignment="CENTER" hgap="3.0" vgap="3.0">
                <padding><Insets bottom="10" left="10" right="10" top="10" /></padding>
            </GridPane>
        </StackPane>
    </center>

    <!-- RIGHT — OPPONENT + LOG -->
    <right>
        <VBox prefWidth="200.0" spacing="0.0"
              style="-fx-background-color: #2d0a3e;
                     -fx-border-color: #f4722b; -fx-border-width: 0 0 0 4;">

            <HBox alignment="CENTER"
                  style="-fx-background-color: #f4722b; -fx-padding: 10 12 10 12;">
                <Label text="👾  OPPONENT"
                       style="-fx-text-fill: #ffffff; -fx-font-weight: bold; -fx-font-size: 12px;" />
            </HBox>

            <!-- Opponent portrait -->
            <StackPane prefHeight="110"
                       style="-fx-background-color: #1e0628;">
                <ImageView fx:id="opponentImage" fitHeight="100" fitWidth="100"
                           preserveRatio="true" pickOnBounds="true" />
            </StackPane>

            <VBox spacing="8.0" style="-fx-background-color: #2d0a3e;">
                <padding><Insets bottom="12" left="12" right="12" top="10" /></padding>

                <Label fx:id="opponentName" text="Loading..."
                       wrapText="true"
                       style="-fx-text-fill: #f9d71c; -fx-font-size: 14px; -fx-font-weight: bold;" />

                <HBox alignment="CENTER_LEFT" spacing="6">
                    <Label text="TYPE"
                           style="-fx-text-fill: #e8a0f0; -fx-font-size: 9px; -fx-font-weight: bold;" />
                    <Label fx:id="opponentType" text="—"
                           style="-fx-text-fill: #ffffff; -fx-font-size: 11px; -fx-font-weight: bold;
                                  -fx-background-color: #f4722b; -fx-background-radius: 6;
                                  -fx-padding: 2 8 2 8;" />
                </HBox>

                <Separator style="-fx-background-color: #5a1a7a;" />

                <HBox alignment="CENTER_LEFT" spacing="6">
                    <Label text="ORIG"
                           style="-fx-text-fill: #e8a0f0; -fx-font-size: 9px; -fx-font-weight: bold; -fx-min-width: 36;" />
                    <Label fx:id="opponentOrigRole" text="—"
                           style="-fx-text-fill: #e8c0f0; -fx-font-size: 11px;" />
                </HBox>

                <HBox alignment="CENTER_LEFT" spacing="6">
                    <Label text="CURR"
                           style="-fx-text-fill: #e8a0f0; -fx-font-size: 9px; -fx-font-weight: bold; -fx-min-width: 36;" />
                    <Label fx:id="opponentCurrRole" text="—"
                           style="-fx-text-fill: #f4722b; -fx-font-size: 11px; -fx-font-weight: bold;" />
                </HBox>

                <Separator style="-fx-background-color: #5a1a7a;" />

                <VBox spacing="2">
                    <Label text="⚡ ENERGY"
                           style="-fx-text-fill: #e8a0f0; -fx-font-size: 9px; -fx-font-weight: bold;" />
                    <Label fx:id="opponentEnergy" text="0"
                           style="-fx-text-fill: #f4722b; -fx-font-size: 30px; -fx-font-weight: bold;" />
                </VBox>

                <HBox alignment="CENTER_LEFT" spacing="6">
                    <Label text="📍 CELL"
                           style="-fx-text-fill: #e8a0f0; -fx-font-size: 9px; -fx-font-weight: bold;" />
                    <Label fx:id="opponentPos" text="0"
                           style="-fx-text-fill: #ffffff; -fx-font-size: 13px; -fx-font-weight: bold;" />
                </HBox>

                <Separator style="-fx-background-color: #5a1a7a;" />

                <Label text="STATUS"
                       style="-fx-text-fill: #e8a0f0; -fx-font-size: 9px; -fx-font-weight: bold;" />
                <VBox fx:id="opponentStatusBox" spacing="4.0" />
            </VBox>

            <Region VBox.vgrow="ALWAYS" />

            <!-- SCREAM LOG -->
            <VBox spacing="5.0" VBox.vgrow="ALWAYS"
                  style="-fx-border-color: #5a1a7a; -fx-border-width: 2 0 0 0;">
                <padding><Insets bottom="8" left="10" right="8" top="8" /></padding>

                <Label text="📜  SCREAM LOG"
                       style="-fx-text-fill: #f9d71c; -fx-font-size: 10px; -fx-font-weight: bold;" />
                <Separator style="-fx-background-color: #f9d71c; -fx-opacity: 0.5;" />

                <ScrollPane fx:id="logScroll" fitToWidth="true" prefHeight="180.0"
                            hbarPolicy="NEVER"
                            style="-fx-background: transparent; -fx-background-color: transparent;"
                            VBox.vgrow="ALWAYS">
                    <VBox fx:id="logBox" spacing="4.0">
                        <padding><Insets bottom="4" left="2" right="4" top="2" /></padding>
                    </VBox>
                </ScrollPane>
            </VBox>
        </VBox>
    </right>

    <!-- BOTTOM — DICE + BUTTONS -->
    <bottom>
        <VBox spacing="0.0"
              style="-fx-background-color: #042030;
                     -fx-border-color: #f9d71c; -fx-border-width: 4 0 0 0;">

            <!-- Event row -->
            <HBox alignment="CENTER" prefHeight="50.0"
                  style="-fx-background-color: #021824;">

                <HBox alignment="CENTER" spacing="12" prefWidth="220"
                      style="-fx-border-color: #0a4060; -fx-border-width: 0 2 0 0;
                             -fx-padding: 6 20 6 20;">
                    <Label text="🎲"
                           style="-fx-font-size: 22px;" />
                    <VBox alignment="CENTER" spacing="0">
                        <Label text="ROLLED"
                               style="-fx-text-fill: #5aaccf; -fx-font-size: 9px; -fx-font-weight: bold;" />
                        <Label fx:id="diceLabel" text="—"
                               style="-fx-text-fill: #f9d71c; -fx-font-size: 28px; -fx-font-weight: bold;" />
                    </VBox>
                </HBox>

                <HBox alignment="CENTER_LEFT" spacing="10" HBox.hgrow="ALWAYS"
                      style="-fx-padding: 6 20 6 20;">
                    <Label text="🚪"
                           style="-fx-font-size: 18px;" />
                    <Label fx:id="eventLabel" text="Waiting for your move..."
                           wrapText="true"
                           style="-fx-text-fill: #a8e063; -fx-font-size: 12px;" />
                </HBox>
            </HBox>

            <!-- Buttons row -->
            <HBox alignment="CENTER" prefHeight="58.0" spacing="28.0"
                  style="-fx-background-color: #042030; -fx-padding: 8 20 8 20;">

                <Button fx:id="powerupBtn"
                        mnemonicParsing="false"
                        onAction="#onUsePowerup"
                        prefHeight="42.0" prefWidth="220.0"
                        text="⚡  ACTIVATE POWERUP"
                        style="-fx-background-color: #a8e063; -fx-text-fill: #042030;
                               -fx-font-weight: bold; -fx-font-size: 12px;
                               -fx-background-radius: 22;
                               -fx-effect: dropshadow(gaussian, #a8e06366, 10, 0, 0, 3);" />

                <Button fx:id="rollBtn"
                        mnemonicParsing="false"
                        onAction="#onRoll"
                        prefHeight="42.0" prefWidth="220.0"
                        text="🎲  ROLL DICE"
                        style="-fx-background-color: #f9d71c; -fx-text-fill: #042030;
                               -fx-font-weight: bold; -fx-font-size: 14px;
                               -fx-background-radius: 22;
                               -fx-effect: dropshadow(gaussian, #f9d71c66, 12, 0, 0, 3);" />
            </HBox>
        </VBox>
    </bottom>

</BorderPane>
